# ===========================================================================
# PRIVATESCORE ENVIRONMENT CONFIGURATION EXAMPLE
# ===========================================================================
# Copy this file to .env.local and fill in your actual values
# This file can be safely committed to version control

# ===========================================================================
# SOLANA NETWORK CONFIGURATION
# ===========================================================================
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ===========================================================================
# PROGRAM IDS
# ===========================================================================
NEXT_PUBLIC_PROGRAM_ID=your_program_id_here

# ===========================================================================
# HELIUS API CONFIGURATION
# ===========================================================================
NEXT_PUBLIC_HELIUS_API_KEY=your_helius_api_key_here

# ===========================================================================
# RPC ENDPOINTS
# ===========================================================================
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_BACKUP_RPC_URLS=https://devnet.genesysgo.net,https://api.devnet.solana.com

# ===========================================================================
# FEATURE FLAGS
# ===========================================================================
NEXT_PUBLIC_ENABLE_REAL_TX=false
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEBUG=false

# ===========================================================================
# ZK PROOF CONFIGURATION
# ===========================================================================
NOIR_BACKEND=barretenberg
PROOF_TIMEOUT=30000

# ===========================================================================
# WEBHOOK CONFIGURATION (Optional)
# ===========================================================================
WEBHOOK_URL=https://your-app.com/api/webhooks/helius
WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================================================
# DATABASE (Optional - for production)
# ===========================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/privatescore
REDIS_URL=redis://localhost:6379

# ===========================================================================
# SECURITY
# ===========================================================================
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_character_encryption_key

# ===========================================================================
# ANALYTICS (Optional)
# ===========================================================================
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ===========================================================================
# DEVELOPMENT
# ===========================================================================
SKIP_WALLET_CONNECTION=false
MOCK_CREDIT_SCORES=true
HOT_RELOAD_CIRCUITS=true